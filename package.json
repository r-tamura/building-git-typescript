{
  "name": "@rtamura30/kit",
  "version": "0.1.0",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "bin": "./bin/kit",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/r-tamura/building-git-typescript.git"
  },
  "license": "ISC",
  "scripts": {
    "clean": "rm -rf dist/*",
    "build:release": "tsc --project tsconfig.prod.json",
    "build": "tsc",
    "watch": "tsc -w",
    "format": "prettier-eslint --write \"$PWD/src/**/*.ts\"",
    "test:all": "vitest run",
    "test:unit": "vitest run --project unit",
    "pretest:integ": "pnpm build:release",
    "test:integ": "vitest run --project integ",
    "pre-commit": "yarn format"
  },
  "devDependencies": {
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^22.15.17",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^7.16.0",
    "eslint-config-prettier": "^7.1.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.3.0",
    "eslint-plugin-promise": "^4.2.1",
    "husky": "^4.3.8",
    "prettier": "^2.2.1",
    "prettier-eslint-cli": "^5.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "arg": "^5.0.0",
    "crc-32": "^1.2.0",
    "mock-fs": "^5.5.0",
    "shlex": "^2.0.2"
  }
}
